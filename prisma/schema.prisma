// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SALES_MANAGER
  SUPPORT
  CUSTOMER
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LeadSource {
  CONTACT_FORM
  GET_STARTED
  SALES_REQUEST
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  CLOSED
  SPAM
}

enum ContactTopic {
  GENERAL
  PRODUCT
  QUOTE
  DISTRIBUTOR
  SUPPORT
}

enum TestimonialStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id              String   @id @default(cuid())
  fullName        String
  email           String   @unique
  passwordHash    String
  phone           String?
  role            UserRole @default(CUSTOMER)
  isActive        Boolean  @default(true)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignedLeads Lead[] @relation("LeadAssignee")

  @@index([role, isActive])
  @@index([createdAt])
}

model ProductCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@unique([name])
  @@index([isActive, sortOrder])
}

model Product {
  id               String        @id @default(cuid())
  categoryId       String?
  name             String
  slug             String        @unique
  sku              String?       @unique
  status           ProductStatus @default(DRAFT)
  shortDescription String
  description      String?
  pricePkr         Decimal?      @db.Decimal(10, 2)
  currency         String        @default("PKR")
  imageUrl         String?
  brochureUrl      String?
  isFeatured       Boolean       @default(false)
  sortOrder        Int           @default(0)
  publishedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  category      ProductCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  features      ProductFeature[]
  nutrientSpecs ProductNutrientSpec[]

  @@index([categoryId])
  @@index([status, isFeatured, sortOrder])
  @@index([publishedAt])
}

model ProductFeature {
  id        String   @id @default(cuid())
  productId String
  value     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([productId, sortOrder])
}

model ProductNutrientSpec {
  id        String   @id @default(cuid())
  productId String
  nutrient  String
  amount    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([productId, sortOrder])
}

model Lead {
  id               String       @id @default(cuid())
  source           LeadSource
  status           LeadStatus   @default(NEW)
  topic            ContactTopic @default(GENERAL)
  fullName         String
  email            String
  phone            String?
  companyName      String?
  subject          String?
  message          String?
  country          String?
  city             String?
  assignedToUserId String?
  contactedAt      DateTime?
  resolvedAt       DateTime?
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  assignedTo User? @relation("LeadAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([status, createdAt])
  @@index([source, createdAt])
  @@index([email])
  @@index([assignedToUserId])
}

model Testimonial {
  id         String            @id @default(cuid())
  name       String
  role       String?
  location   String?
  quote      String
  accentFrom String?
  accentTo   String?
  status     TestimonialStatus @default(DRAFT)
  sortOrder  Int               @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([status, sortOrder])
}

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  fullName       String?
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([isActive, subscribedAt])
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
